{
  "id": "mongodb-uri",
  "name": "MongoDB URI",
  "version": "0.2.0",
  "description": "MongoDB driver that connects with a full connection URI (mongodb:// or mongodb+srv://), with SRV, TLS and Atlas support",
  "default_port": 27017,
  "executable": "tabularis-mongodb-plugin",
  "capabilities": {
    "schemas": false,
    "views": false,
    "routines": false,
    "file_based": false,
    "connection_string": true,
    "connection_uri": true,
    "connection_uri_schemes": ["mongodb", "mongodb+srv"],
    "identifier_quote": "`",
    "alter_primary_key": false
  },
  "data_types": [
    {
      "name": "String",
      "category": "string",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "Int32",
      "category": "numeric",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "Int64",
      "category": "numeric",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "Double",
      "category": "numeric",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "Decimal128",
      "category": "numeric",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "Boolean",
      "category": "other",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "Date",
      "category": "date",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "ObjectId",
      "category": "other",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "Array",
      "category": "other",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "Object",
      "category": "other",
      "requires_length": false,
      "requires_precision": false
    },
    {
      "name": "Binary",
      "category": "binary",
      "requires_length": false,
      "requires_precision": false
    }
  ]
}
